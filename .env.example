# ============================================
# GMGN SNIPER BOT — ENVIRONMENT CONFIG
# ============================================

# WALLET
PRIVATE_KEY=your_solana_private_key_base58_here

# RPC
RPC_ENDPOINT=https://api.mainnet-beta.solana.com
RPC_WS=wss://api.mainnet-beta.solana.com

# PRIORITY FEE (microLamports per compute unit)
# 100000 = ~0.0001 SOL / tx — adjust based on network congestion
PRIORITY_FEE=500000

# SLIPPAGE (%)
SLIPPAGE=15

# JUPITER API
JUPITER_API=https://quote-api.jup.ag/v6

# TARGET PROFIT PER ENTRY IN USD
TP_USD=5.00

# MAX BUY AMOUNT PER TOKEN IN SOL
BUY_AMOUNT_SOL=0.01

# COOLDOWN BETWEEN ENTRIES (ms)
COOLDOWN_MS=2000

# LOG LEVEL: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# PISANGGORENG SNIPER BOT v2.0 — ENVIRONMENT
# ============================================

# ─── WALLET ──────────────────────────────────
PRIVATE_KEY=your_solana_private_key_base58_here

# ─── RPC ─────────────────────────────────────
RPC_ENDPOINT=https://api.mainnet-beta.solana.com
RPC_WS=wss://api.mainnet-beta.solana.com

# ─── FEES & SLIPPAGE ─────────────────────────
PRIORITY_FEE=500000
SLIPPAGE=15

# ─── TRADING ─────────────────────────────────
BUY_AMOUNT_SOL=0.01
COOLDOWN_MS=2000

# ─── TP / SL / PARTIAL TP / MOONBAG ──────────
TP_USD=5.00
STOP_LOSS_USD=0               # 0 = disabled (e.g. set to 2 for -$2 stop loss)
ENABLE_PARTIAL_TP=true        # true = sell some at TP, hold the rest
PARTIAL_SELL_PCT=50           # sell 50% at first TP
MOONBAG_HOLD_PCT=25           # hold 25% after partial sell
MOONBAG_TP_USD=20             # sell moonbag at $20 profit

# ─── ANTI-SCAM ───────────────────────────────
ENABLE_ANTI_SCAM=true         # false to skip checks
ENABLE_HONEYPOT_CHECK=false   # true = also check sell quotes before buying

# ─── TELEGRAM ────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── JITO BUNDLE ENGINE ──────────────────────
ENABLE_JITO=false               # true = bypass mempool via Jito
JITO_TIP_AMOUNT=0.0001          # SOL tip for Jito validators
JITO_BLOCK_ENGINE=https://mainnet.block-engine.jito.wtf

# ─── HELIUS RPC (recommended — no rate limits) ─
# Daftar gratis di https://www.helius.dev untuk API key
# Kalo diisi, bot pake Helius sebagai RPC utama
HELIUS_API_KEY=

# ─── LOG ─────────────────────────────────────
LOG_LEVEL=info
